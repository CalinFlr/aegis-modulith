# Deployment and local-container environment example.
# Copy values into your platform secret store, shell, or a local untracked .env file.
# Do not commit real passwords, JWT signing keys, registry tokens, or cloud credentials.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
AllowedHosts=example.invalid

ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=aegis_template;Username=aegis_app;Password=replace-with-user-supplied-secret

Authentication__Jwt__Issuer=https://issuer.example
Authentication__Jwt__Audience=aegis-api
Authentication__Jwt__SigningKey=replace-with-user-supplied-secret-at-least-32-bytes
Authentication__Jwt__RequireHttpsMetadata=true

Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning

OTEL_SERVICE_NAME=Aegis.Template.Api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.example:4317

Inbox__EnableBackgroundProcessor=false
Resilience__DefaultTimeoutSeconds=10

POSTGRES_DB=aegis_template
POSTGRES_USER=aegis_app
POSTGRES_PASSWORD=replace-with-local-dev-password
