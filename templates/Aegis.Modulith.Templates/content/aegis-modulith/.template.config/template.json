{
  "$schema": "http://json.schemastore.org/template",
  "author": "Aegis.Modulith contributors",
  "classifications": [
    "Web",
    "API",
    "Modular Monolith",
    "CQRS"
  ],
  "identity": "Aegis.Modulith.Templates.Modulith",
  "name": "Aegis.Modulith API",
  "shortName": "aegis-modulith",
  "sourceName": "Aegis.Template",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
        "LICENSE",
        "LICENSE.apache2",
        "LICENSE.mit"
      ],
      "modifiers": [
        {
          "condition": "(profile == \"core\")",
          "exclude": [
            "Dockerfile",
            "src/Aegis.Template.Api/Pro/**",
            "src/Aegis.Template.AppHost/**",
            "src/Aegis.Template.ServiceDefaults/**",
            "tests/Aegis.Template.ContractTests/**",
            "tests/Aegis.Template.IntegrationTests/**"
          ]
        },
        {
          "condition": "(profile != \"advanced\")",
          "exclude": [
            "src/Aegis.Template.Api/Advanced/**"
          ]
        },
        {
          "condition": "(sample == \"taskhub\")",
          "exclude": [
            "src/Aegis.Template.Modules/Modules/WorkItems/**"
          ]
        },
        {
          "condition": "(sample != \"taskhub\")",
          "exclude": [
            "src/Aegis.Template.Modules/Modules/Audit/**",
            "src/Aegis.Template.Modules/Modules/Notifications/**",
            "src/Aegis.Template.Modules/Modules/Projects/**",
            "src/Aegis.Template.Modules/Modules/Tasks/**"
          ]
        },
        {
          "condition": "(hooks != \"lefthook\")",
          "exclude": [
            "lefthook.yml"
          ]
        },
        {
          "condition": "(guardrails == \"off\")",
          "exclude": [
            "package.json",
            "tools/guardrails/**"
          ]
        },
        {
          "condition": "(guardrails != \"strict\")",
          "exclude": [
            ".ai/guardrails/strict-rules.md",
            ".ai/policies/strict-mode.md"
          ]
        },
        {
          "condition": "(ai == \"none\")",
          "exclude": [
            "AGENTS.md",
            "CLAUDE.md",
            "OpenQuestions.md",
            ".github/copilot-instructions.md",
            ".ai/**",
            ".agents/**",
            "docs/ai-development/**",
            "specs/**"
          ]
        },
        {
          "condition": "(ai != \"enterprise\")",
          "exclude": [
            ".ai/**",
            ".agents/**",
            "docs/ai-development/guardrails.md",
            "docs/ai-development/skills.md",
            "docs/ai-development/spec-driven-development.md",
            "docs/ai-development/workflows.md",
            "specs/**"
          ]
        },
        {
          "condition": "(skills == \"none\")",
          "exclude": [
            ".agents/skills/**"
          ]
        },
        {
          "condition": "(skills == \"core\")",
          "exclude": [
            ".agents/skills/competitive-review/**",
            ".agents/skills/efcore-migration-review/**",
            ".agents/skills/guardrail-runner/**",
            ".agents/skills/module-manifest-review/**",
            ".agents/skills/openapi-contract-review/**",
            ".agents/skills/security-review/**"
          ]
        },
        {
          "condition": "(docs != \"full\")",
          "exclude": [
            "docs/ai-development/**",
            "docs/adr/**",
            "docs/operations.md",
            "docs/security.md"
          ]
        }
      ]
    },
    {
      "source": "./",
      "target": "./",
      "condition": "(license == \"apache2\")",
      "include": [
        "LICENSE.apache2"
      ],
      "rename": {
        "LICENSE.apache2": "LICENSE"
      }
    },
    {
      "source": "./",
      "target": "./",
      "condition": "(license == \"mit\")",
      "include": [
        "LICENSE.mit"
      ],
      "rename": {
        "LICENSE.mit": "LICENSE"
      }
    }
  ],
  "symbols": {
    "profile": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "pro",
      "replaces": "AegisProfileValue",
      "description": "Generated profile.",
      "choices": [
        { "choice": "core", "description": "Minimal production-minded API foundation." },
        { "choice": "pro", "description": "Recommended default with Aspire-ready and operational scaffolding." },
        { "choice": "advanced", "description": "Enterprise scaffolding with tenancy and permission placeholders." }
      ]
    },
    "mediator": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "core",
      "replaces": "AegisMediatorValue",
      "description": "Dispatch implementation.",
      "choices": [
        { "choice": "core", "description": "Lightweight built-in dispatcher." },
        { "choice": "mediatr", "description": "Optional MediatR adapter path." }
      ]
    },
    "AEGIS_MEDIATR": {
      "type": "computed",
      "value": "(mediator == \"mediatr\")"
    },
    "AEGIS_CORE_MEDIATOR": {
      "type": "computed",
      "value": "(mediator == \"core\")"
    },
    "AEGIS_PRO_OR_ADVANCED": {
      "type": "computed",
      "value": "(profile != \"core\")"
    },
    "AEGIS_ADVANCED": {
      "type": "computed",
      "value": "(profile == \"advanced\")"
    },
    "database": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "postgres",
      "replaces": "AegisDatabaseValue",
      "description": "Database provider.",
      "choices": [
        { "choice": "postgres", "description": "PostgreSQL." }
      ]
    },
    "sample": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "none",
      "replaces": "AegisSampleValue",
      "description": "Reference sample.",
      "choices": [
        { "choice": "none", "description": "Generate starter modules." },
        { "choice": "taskhub", "description": "Generate TaskHub sample modules." }
      ]
    },
    "ai": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "enterprise",
      "replaces": "AegisAiValue",
      "choices": [
        { "choice": "none", "description": "No AI assets." },
        { "choice": "agents", "description": "Agent instructions only." },
        { "choice": "enterprise", "description": "Agent instructions and enterprise guardrails." }
      ]
    },
    "guardrails": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "standard",
      "replaces": "AegisGuardrailsValue",
      "choices": [
        { "choice": "off", "description": "No generated guardrail runner." },
        { "choice": "standard", "description": "Standard guardrail checks." },
        { "choice": "strict", "description": "Strict enterprise guardrail stance." }
      ]
    },
    "hooks": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "none",
      "replaces": "AegisHooksValue",
      "choices": [
        { "choice": "none", "description": "No hooks." },
        { "choice": "lefthook", "description": "Generate Lefthook config." }
      ]
    },
    "skills": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "enterprise",
      "replaces": "AegisSkillsValue",
      "choices": [
        { "choice": "none", "description": "No generated skills." },
        { "choice": "core", "description": "Core skills." },
        { "choice": "enterprise", "description": "Enterprise skills." }
      ]
    },
    "docs": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "full",
      "replaces": "AegisDocsValue",
      "choices": [
        { "choice": "standard", "description": "Standard docs." },
        { "choice": "full", "description": "Full docs." }
      ]
    },
    "license": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "apache2",
      "replaces": "AegisLicenseValue",
      "choices": [
        { "choice": "apache2", "description": "Apache-2.0." },
        { "choice": "mit", "description": "MIT." }
      ]
    },
    "licenseExpression": {
      "type": "generated",
      "generator": "switch",
      "datatype": "string",
      "replaces": "AegisLicenseExpressionValue",
      "parameters": {
        "evaluator": "C++",
        "cases": [
          { "condition": "(license == \"apache2\")", "value": "Apache-2.0" },
          { "condition": "(license == \"mit\")", "value": "MIT" }
        ]
      }
    },
    "licenseName": {
      "type": "generated",
      "generator": "switch",
      "datatype": "string",
      "replaces": "AegisLicenseNameValue",
      "parameters": {
        "evaluator": "C++",
        "cases": [
          { "condition": "(license == \"apache2\")", "value": "Apache License 2.0" },
          { "condition": "(license == \"mit\")", "value": "MIT License" }
        ]
      }
    }
  },
  "primaryOutputs": [
    { "path": "Aegis.Template.sln" }
  ],
  "specialCustomOperations": {
    "**/*.md": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "#if" ],
            "else": [ "#else" ],
            "elseif": [ "#elseif", "#elif" ],
            "endif": [ "#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    },
    "**/*.yml": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "#if" ],
            "else": [ "#else" ],
            "elseif": [ "#elseif", "#elif" ],
            "endif": [ "#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    },
    "**/*.yaml": {
      "operations": [
        {
          "type": "conditional",
          "configuration": {
            "if": [ "#if" ],
            "else": [ "#else" ],
            "elseif": [ "#elseif", "#elif" ],
            "endif": [ "#endif" ],
            "trim": true,
            "wholeLine": true,
            "evaluator": "C++"
          }
        }
      ]
    }
  }
}
