{
  "$schema": "http://json.schemastore.org/template",
  "author": "Aegis.Modulith contributors",
  "classifications": [
    "Aegis.Modulith",
    "Event"
  ],
  "identity": "Aegis.Modulith.Templates.Event",
  "name": "Aegis domain or integration event",
  "shortName": "aegis-event",
  "sourceName": "Aegis.Event",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "sources": [
    {
      "source": "./",
      "target": "./",
      "modifiers": [
        {
          "condition": "(scope == \"domain\")",
          "exclude": [
            "Contracts/**"
          ]
        },
        {
          "condition": "(scope == \"integration\")",
          "exclude": [
            "Domain/**"
          ]
        }
      ]
    }
  ],
  "symbols": {
    "rootNamespace": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "Aegis.Template.Modules",
      "replaces": "AegisItemRootNamespace",
      "description": "Root namespace of the generated modules project, for example Acme.WorkHub.Modules."
    },
    "buildingBlocksNamespace": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "Aegis.Template.BuildingBlocks",
      "replaces": "AegisBuildingBlocksNamespace",
      "description": "Namespace of the generated BuildingBlocks project, for example Acme.WorkHub.BuildingBlocks."
    },
    "module": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "Module",
      "replaces": "AegisEventModule"
    },
    "scope": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "domain",
      "replaces": "AegisEventScope",
      "choices": [
        { "choice": "domain", "description": "Domain event." },
        { "choice": "integration", "description": "Integration event." }
      ]
    }
  }
}
